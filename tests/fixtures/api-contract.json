{
  "access": {
    "check": {
      "request": {
        "path": "/access/check",
        "method": "GET",
        "query": ["address", "guildId", "resourceId"]
      },
      "response": {
        "success": {
          "hasAccess": true,
          "walletAddress": "0x1234567890123456789012345678901234567890",
          "guildId": "guild_1",
          "resourceId": "res_1",
          "requiredRoles": ["role1"],
          "matchedRoles": ["role1"]
        },
        "error": {
          "code": "INTERNAL_ERROR",
          "message": "Internal Server Error"
        }
      }
    },
    "roleCheck": {
      "request": {
        "path": "/access/role-check",
        "method": "GET",
